# Copy to .env and set your key. Do not commit .env.
OPENAI_API_KEY=sk-your-key-here

# Optional: enable dev-only UI and advanced tools (philosopher panels, note debug boxes, etc.). Does not disable the AI.
# DEV=1

# Optional: disable LLM calls; return dummy responses and do not require OPENAI_API_KEY.
# OFFLINE=1

# Optional: model (default: gpt-4o). Use gpt-4o-mini for cheapest standard rate.
OPENAI_MODEL=gpt-4o-mini

# Optional: service tier. Set to "flex" for ~50% cheaper, slower (non-time-sensitive).
# Flex is supported for some models (e.g. o3, o4-mini). Leave commented for standard tier.
# OPENAI_SERVICE_TIER=flex

# Optional: directory containing prompt.md, closers.md, etc. (if auto-resolution fails).
# PROMPTS_DIR=/Users/you/projects/ExistentialDetectiveAgency/frontend/api/prompts

# Optional: path to philosopher_notes.json (default: frontend/public/data/philosopher_notes.json).
# PHILOSOPHER_NOTES_FILE=/path/to/philosopher_notes.json

# Optional: path to agent instructions (markdown). Default: api/prompts/prompt.md
# AGENT_PROMPT_FILE=/path/to/prompt.md

# Optional: port (default: 3011)
PORT=3011

# Optional: verbose logging — /api/debug endpoint, server and request logs (including full message sent to the LLM), debug info in chat responses.
# DEBUG_LOGS=1

# Optional: max exchanges per user session before showing closers (default: 5)
# MAX_USER_EXCHANGES=5

# Optional: max total API calls per day across all users (default: 100)
# MAX_DAILY_USAGE=100
