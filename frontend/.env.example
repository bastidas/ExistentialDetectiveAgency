# Copy to .env and set your key. Do not commit .env.
OPENAI_API_KEY=sk-your-key-here

# Optional: enable dev-only UI and advanced tools (philosopher panels, note debug boxes, etc.). Does not disable the AI.
# DEV=1

# Optional: disable LLM calls; return dummy responses and do not require OPENAI_API_KEY.
# OFFLINE=1

# Optional: model (default: gpt-4o). Use gpt-4o-mini for cheapest standard rate.
OPENAI_MODEL=gpt-4o-mini

# Optional: service tier. Set to "flex" for ~50% cheaper, slower (non-time-sensitive).
# Flex is supported for some models (e.g. o3, o4-mini). Leave commented for standard tier.
# OPENAI_SERVICE_TIER=flex

# Optional: directory containing prompt.md, closers.md, etc. (if auto-resolution fails).
# PROMPTS_DIR=/Users/you/projects/ExistentialDetectiveAgency/frontend/api/prompts

# Optional: path to philosopher_notes.json (default: frontend/public/data/philosopher_notes.json).
# PHILOSOPHER_NOTES_FILE=/path/to/philosopher_notes.json

# Optional: path to agent instructions (markdown). Default: api/prompts/prompt.md
# AGENT_PROMPT_FILE=/path/to/prompt.md

# Optional: port (default: 3011)
PORT=3011

# Optional: verbose logging — /api/debug endpoint, server and request logs (including full message sent to the LLM), debug info in chat responses.
# DEBUG_LOGS=1

# Optional: max exchanges per user session before showing closers (default: 5)
# MAX_USER_EXCHANGES=5

# Optional: max total API calls per day across all users (default: 100)
# MAX_DAILY_USAGE=100

# --- Optional: Azure Table Storage (session, dossier, usage, chat restore) ---
# Set both to enable durable storage (unless ENABLE_DURABLE_STORAGE=0).
# Greenfield partitions: EDA_session, EDA_dossier, EDA_usageSession, EDA_usageDaily — recreate table if upgrading from legacy keys.
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# DOSSIER_TABLE_NAME=UserDossiers
# ENABLE_DURABLE_STORAGE=0
# MAX_THREAD_EVENTS=400
# MAX_THREAD_JSON_CHARS=800000

# --- Session return / rehydration policy (time-away → optional baseline refresh) ---
# Default: policy ON. Set to 0/false/no to disable classification + routing.
# ENABLE_RETURN_POLICY=0
# Log classification only; do not restart baseline (staging).
# RETURN_POLICY_LOG_ONLY=1
# Time-away policy (hours → converted internally to ms):
# TIME_AWAY_BRIEF_HOURS=0.25   # “just stepped away” / same visit (default 15 min)
# TIME_AWAY_LONG_HOURS=42      # long absence, ~a day or few
# TIME_AWAY_STALE_HOURS=32     # baseline age before “stale” in middle bucket; raise for week-scale
# Dev: allow sub-minute / sub-hour effective windows (do not use in prod):
# TIME_AWAY_DISABLE_MIN_GUARDS=1
# Optional ms overrides (win over hours):
# TIME_AWAY_BRIEF_MS=900000
# TIME_AWAY_LONG_MS=...
# TIME_AWAY_STALE_MS=...
